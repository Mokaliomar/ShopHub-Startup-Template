@{
    ViewBag.PageTitle = "Products Management";
    ViewBag.CardTitle = "View Products";
    Layout = "~/Views/Shared/_Dashboard.cshtml";
}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
<link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/jquery.dataTables.min.css" />

<style>
    /* Fancy Card */
    .custom-card {
        background: rgba(255, 255, 255, 0.75);
        backdrop-filter: blur(12px);
        border-radius: 18px;
        border: 1px solid rgba(160, 173, 186, 0.35);
        box-shadow: 0 15px 35px rgba(0,0,0,0.12);
        padding: 28px;
        animation: fadeIn .4s ease;
    }

    @@keyframes fadeIn {
        from

    {
        opacity: 0;
        transform: translateY(8px);
    }

    to {
        opacity: 1;
        transform: translateY(0);
    }

    }

    /* Header Inside Card */
    .custom-card-title {
        background: linear-gradient(135deg, #1e3a8a, #3b82f6);
        padding: 18px;
        border-radius: 14px;
        margin-bottom: 22px;
        text-align: center;
        color: white;
        font-weight: 700;
        letter-spacing: .6px;
        font-size: 22px;
        box-shadow: 0 4px 20px rgba(30,58,138,.35);
    }

    /* Create button */
    .top-btn {
        margin-bottom: 18px;
        text-align: right;
    }

    .btn-primary {
        padding: 10px 22px;
        border-radius: 10px;
        font-weight: 600;
        border: none;
        background: linear-gradient(135deg, #1e40af, #2563eb);
        box-shadow: 0 6px 20px rgba(37,99,235,0.35);
        color: white;
        transition: .25s ease;
    }

        .btn-primary:hover {
            background: linear-gradient(135deg, #1e3a8a, #1d4ed8);
            box-shadow: 0 8px 25px rgba(37,99,235,0.45);
            transform: translateY(-2px);
        }

    /* DataTable - Header */
    #mytable thead th {
        background: #1e40af !important;
        color: white !important;
        padding: 14px !important;
        border: none !important;
        font-size: 15px;
        font-weight: 600;
        border-radius: 10px 10px 0 0;
    }

    /* Fancy Rows */
    #mytable tbody td {
        background: white !important;
        padding: 14px !important;
        color: #1e3a8a;
        border-bottom: 1px solid #e3e8ef !important;
    }

    #mytable tbody tr {
        transition: .2s ease;
    }

        #mytable tbody tr:hover td {
            background: #ebf2ff !important;
            cursor: pointer;
        }

    /* Actions Buttons */
    .action-btn {
        padding: 7px 14px;
        border-radius: 8px;
        font-size: 13px;
        font-weight: 600;
        margin-right: 6px;
        transition: .2s ease;
    }

    .btn-success {
        background: #16a34a;
        color: white;
        border: none;
        box-shadow: 0 4px 12px rgba(22,163,74,0.35);
    }

    .btn-danger {
        background: #dc2626;
        color: white;
        border: none;
        box-shadow: 0 4px 12px rgba(220,38,38,0.35);
    }

    .btn-success:hover {
        background: #15803d;
    }

    .btn-danger:hover {
        background: #b91c1c;
    }
</style>

<div class="custom-card">

    <!-- Elegant title inside the card -->
    <div class="custom-card-title">
        <i class="fa-solid fa-box-open me-2"></i> Products List
    </div>

    <div class="top-btn">
        <a class="btn btn-primary" href="/Admin/Product/Create">
            <i class="fa-solid fa-circle-plus me-1"></i> Create Product
        </a>
    </div>

    <table id="mytable" class="display table-hover" width="100%">
        <thead>
            <tr>
                <th>Name</th>
                <th>Description</th>
                <th>Price</th>
                <th>Category</th>
                <th style="width:130px;">Actions</th>
            </tr>
        </thead>
    </table>
</div>

@section Scripts {
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="~/js/products.js"></script>
}
