@model ProductListVM // أو ProductListDto حسب اسم الـ Model المرسل من الكنترولر

@{
    ViewBag.PageTitle = "Welcome to Our Shop";
    ViewBag.CardTitle = "Explore Our Products";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />

<style>
    /* العنوان الرئيسي المتناسق مع بقية الصفحات */
    .shop-header {
        background: #f1f5fb;
        border: 1px solid #d0d7de;
        border-radius: 14px;
        padding: 15px 25px;
        margin-top: 30px;
        margin-bottom: 25px;
        box-shadow: 0 4px 15px rgba(0, 0, 0, 0.05);

        /* 🟢 التعديل الجوهري للتحكم في الأماكن */
        display: flex;
        align-items: center;
        justify-content: space-between;
        position: relative;
    }

    /* زر السلة الشيك */
    .btn-cart-header {
        background-color: #1e40af;
        color: #ffffff;
        padding: 9px 18px;
        border-radius: 10px;
        font-weight: 600;
        font-size: 0.9rem;
        text-decoration: none;
        transition: all 0.25s ease;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        box-shadow: 0 4px 10px rgba(30, 64, 175, 0.2);
    }

    .btn-cart-header:hover {
        background-color: #1e3a8a;
        color: #ffffff;
        transform: translateY(-2px);
        box-shadow: 0 6px 15px rgba(30, 64, 175, 0.3);
    }

    .shop-header h2 {
        color: #1e3a8a;
        font-weight: 700;
        margin: 0;
    }

    /* شريط البحث والفلترة العلوي */
    .filter-bar {
        background: #ffffff;
        border: 1px solid #e2e8f0;
        border-radius: 12px;
        padding: 16px 20px;
        margin-bottom: 30px;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.04);
    }

    .form-control-custom,
    .form-select-custom {
        border-radius: 8px;
        border: 1px solid #cbd5e1;
        padding: 10px 14px;
        font-size: 0.95rem;
    }

    .form-control-custom:focus,
    .form-select-custom:focus {
        border-color: #1e40af;
        box-shadow: 0 0 0 3px rgba(30, 64, 175, 0.15);
    }

    /* كارت المنتج */
    .product-card {
        background: #ffffff;
        border: 1px solid #d0d7de;
        border-radius: 14px;
        box-shadow: 0 8px 20px rgba(0, 0, 0, 0.08);
        transition: transform 0.3s ease, box-shadow 0.3s ease;
        height: 100%;
        display: flex;
        flex-direction: column;
        overflow: hidden;
    }

    .product-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 12px 25px rgba(30, 64, 175, 0.15);
    }

    .product-img-wrapper {
        background-color: #f8fafc;
        padding: 15px;
        height: 220px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-bottom: 1px solid #e2e8f0;
    }

    .product-img {
        max-height: 100%;
        max-width: 100%;
        object-fit: contain;
        border-radius: 8px;
    }

    .product-body {
        padding: 18px;
        display: flex;
        flex-direction: column;
        flex-grow: 1;
    }

    .product-category {
        font-size: 0.8rem;
        text-transform: uppercase;
        color: #7f9cf5;
        font-weight: 700;
        margin-bottom: 5px;
        letter-spacing: 0.5px;
    }

    .product-title {
        color: #1e3a8a;
        font-weight: 700;
        font-size: 1.15rem;
        margin-bottom: 8px;
        line-height: 1.4;
    }

    .product-description {
        color: #4a5568;
        font-size: 0.9rem;
        margin-bottom: 15px;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
        flex-grow: 1;
    }

    .product-footer {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-top: auto;
        border-top: 1px solid #f1f5fb;
        padding-top: 12px;
    }

    .product-price {
        color: #1e40af;
        font-weight: 700;
        font-size: 1.3rem;
    }

    .btn-details {
        padding: 8px 16px;
        font-weight: 600;
        border-radius: 8px;
        background-color: #1e40af;
        color: white;
        border: none;
        transition: 0.2s ease;
        box-shadow: 0 4px 10px rgba(30, 64, 175, 0.2);
        text-decoration: none;
        font-size: 0.85rem;
    }

    .btn-details:hover {
        background-color: #1e3a8a;
        color: white;
        box-shadow: 0 6px 12px rgba(30, 64, 175, 0.3);
    }

    /* التنسيق الخاص بالـ Pagination */
    .pagination-custom .page-item .page-link {
        color: #1e40af;
        border: 1px solid #cbd5e1;
        border-radius: 8px;
        margin: 0 3px;
        font-weight: 600;
        padding: 8px 14px;
        transition: all 0.2s ease;
    }

    .pagination-custom .page-item.active .page-link {
        background-color: #1e40af;
        border-color: #1e40af;
        color: #ffffff;
        box-shadow: 0 4px 10px rgba(30, 64, 175, 0.25);
    }

    .pagination-custom .page-item.disabled .page-link {
        color: #94a3b8;
        background-color: #f8fafc;
        border-color: #e2e8f0;
    }

    .pagination-custom .page-item .page-link:hover:not(.active) {
        background-color: #eff6ff;
        border-color: #93c5fd;
    }
</style>

<div class="container mb-5">
    <!-- Header -->
    <div class="shop-header">
        <h2><i class="fa-solid fa-store me-2"></i> @ViewBag.CardTitle</h2>
        <!-- زر السلة المضاف في السهم الأحمر -->
        <a asp-controller="Order" asp-action="Cart" class="btn-cart-header">
            <i class="fa-solid fa-cart-shopping"></i>
            <span>My Cart</span>
        </a>
    </div>

    <!-- ================================================================= -->
    <!-- 🟢 START: SEARCH & SORT BAR (شريط البحث والترتيب العلوي) -->
    <!-- ================================================================= -->
    <div class="filter-bar">
        <form asp-action="Index" method="get" class="row g-3 align-items-center">

            <!-- 1. Search Box (مربع البحث عن منتج) -->
            <div class="col-12 col-md-5">
                <div class="input-group">
                    <span class="input-group-text bg-white border-end-0 text-muted" style="border-radius: 8px 0 0 8px;">
                        <i class="fa-solid fa-magnifying-glass"></i>
                    </span>
                    <input type="text" name="searchTerm" value="@Model?.SearchTerm"
                           class="form-control form-control-custom border-start-0"
                           placeholder="Search by product name or description..." />
                </div>
            </div>

            <!-- 2. Sort Dropdown (قائمة الترتيب) -->
            <div class="col-12 col-sm-6 col-md-4">
                <div class="d-flex align-items-center gap-2">
                    <label class="form-label mb-0 fw-bold text-secondary text-nowrap">
                        <i class="fa-solid fa-arrow-down-short-wide me-1"></i> Sort By:
                    </label>
                    <select name="sortingTerm" class="form-select form-select-custom">
                        <option value="">Default (Name A-Z)</option>
                        <option value="NameAsc" selected="@(Model?.SortingTerm == "NameAsc")">Name (A-Z)</option>
                        <option value="NameDesc" selected="@(Model?.SortingTerm == "NameDesc")">Name (Z-A)</option>
                        <option value="PriceAsc" selected="@(Model?.SortingTerm == "PriceAsc")">Price (Low to High)
                        </option>
                        <option value="PriceDesc" selected="@(Model?.SortingTerm == "PriceDesc")">Price (High to Low)
                        </option>
                    </select>
                </div>
            </div>

            <!-- 3. Actions (زر البحث وزر إزالة الفلترة) -->
            <div class="col-12 col-sm-6 col-md-3 d-flex gap-2 justify-content-end">
                <button type="submit" class="btn btn-primary w-100 fw-semibold"
                        style="border-radius: 8px; background-color: #1e40af;">
                    <i class="fa-solid fa-filter me-1"></i> Apply
                </button>

                @if (!string.IsNullOrEmpty(Model?.SearchTerm) || !string.IsNullOrEmpty(Model?.SortingTerm))
                {
                    <a asp-action="Index" class="btn btn-outline-secondary" title="Clear Filters"
                       style="border-radius: 8px;">
                        <i class="fa-solid fa-xmark"></i>
                    </a>
                }
            </div>

        </form>
    </div>
    <!-- ================================================================= -->
    <!-- 🔴 END: SEARCH & SORT BAR -->
    <!-- ================================================================= -->


    <!-- Product Grid -->
    <div class="row g-4">
        @if (Model != null && Model.Items != null && Model.Items.Any())
        {
            @foreach (var item in Model.Items)
            {
                <div class="col-12 col-sm-6 col-md-4 col-lg-3">
                    <div class="product-card">

                        <div class="product-img-wrapper">
                            @if (!string.IsNullOrEmpty(item.Image))
                            {
                                <img src="~/@item.Image" class="product-img" alt="@item.Name" />
                            }
                            else
                            {
                                <img src="~/Images/No-Image-Placeholder.svg" class="product-img" alt="No Image Available" />
                            }
                        </div>

                        <div class="product-body">
                            <span class="product-category">
                                <i class="fa-solid fa-layer-group"></i> @item.CategoryName
                            </span>
                            <h5 class="product-title">@item.Name</h5>
                            <p class="product-description">@item.Description</p>

                            <div class="product-footer">
                                <span class="product-price">
                                    $@item.Price.ToString("F2")
                                </span>
                                <a asp-controller="Home" asp-action="Details" asp-route-id="@item.Id" class="btn-details">
                                    <i class="fa-solid fa-eye me-1"></i> View Details
                                </a>
                            </div>
                        </div>

                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12 text-center my-5 py-4 bg-light rounded-3">
                <i class="fa-solid fa-box-open fa-3x mb-3 text-muted"></i>
                <h4 class="text-secondary fw-semibold">No products found matching your search criteria.</h4>
                <p class="text-muted mb-3">Try adjusting your filters or search terms.</p>
                <a asp-action="Index" class="btn btn-outline-primary rounded-pill px-4">
                    <i class="fa-solid fa-rotate-left me-1"></i> Reset Search
                </a>
            </div>
        }
    </div>


    <!-- ================================================================= -->
    <!-- 🟢 START: PAGINATION BAR (مكون الصفحات السفلي) -->
    <!-- ================================================================= -->
    @if (Model != null && Model.TotalPages >= 1)
    {
        <div class="d-flex justify-content-between align-items-center mt-5 pt-3 border-top">

            <!-- نص توضيحي لرقم الصفحة الحالية -->
            <div class="text-muted small fw-semibold">
                Showing Page <span class="text-dark font-bold">@Model.PageIndex</span> of <span
                class="text-dark font-bold">@Model.TotalPages</span>
            </div>

            <!-- أزرار التنقل بين الصفحات -->
            <nav aria-label="Product Pages Navigation">
                <ul class="pagination pagination-custom mb-0">

                    <!-- زر الصفحة السابقة (Previous) -->
                    <li class="page-item @(!Model.HasPreviousPage ? "disabled" : "")">
                        <a class="page-item-link page-link" asp-action="Index" asp-route-pageNumber="@(Model.PageIndex - 1)"
                           asp-route-searchTerm="@Model.SearchTerm" asp-route-sortingTerm="@Model.SortingTerm">
                            <i class="fa-solid fa-chevron-left me-1"></i> Prev
                        </a>
                    </li>

                    <!-- أرقام الصفحات (1, 2, 3...) -->
                    @for (int i = 1; i <= Model.TotalPages; i++)
                    {
                        <li class="page-item @(i == Model.PageIndex ? "active" : "")">
                            <a class="page-link" asp-action="Index" asp-route-pageNumber="@i"
                               asp-route-searchTerm="@Model.SearchTerm" asp-route-sortingTerm="@Model.SortingTerm">
                                @i
                            </a>
                        </li>
                    }

                    <!-- زر الصفحة التالية (Next) -->
                    <li class="page-item @(!Model.HasNextPage ? "disabled" : "")">
                        <a class="page-link" asp-action="Index" asp-route-pageNumber="@(Model.PageIndex + 1)"
                           asp-route-searchTerm="@Model.SearchTerm" asp-route-sortingTerm="@Model.SortingTerm">
                            Next <i class="fa-solid fa-chevron-right ms-1"></i>
                        </a>
                    </li>

                </ul>
            </nav>

        </div>
    }
    <!-- ================================================================= -->
    <!-- 🔴 END: PAGINATION BAR -->
    <!-- ================================================================= -->

</div>